SERVICE_NAME=payment-service
ENVIRONMENT=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://delivery:delivery_secret@payment-db:5432/payment_db

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=payment-service-group

REDIS_URL=redis://localhost:6379/0

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_ENABLED=true

# Simulation controls — tune for demos
SIMULATED_FAILURE_RATE=0.1
SIMULATED_PROCESSING_DELAY=0.3
MAX_TRANSACTION_AMOUNT_CENTS=100000
