SERVICE_NAME=restaurant-service
ENVIRONMENT=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://delivery:delivery_secret@restaurant-db:5432/restaurant_db

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=restaurant-service-group

REDIS_URL=redis://localhost:6379/0
REDIS_MENU_TTL=300
REDIS_ITEM_AVAIL_TTL=120

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_ENABLED=true

# Set to false in production — real kitchen operator confirms
AUTO_CONFIRM_ORDERS=true
AUTO_CONFIRM_DELAY_SECONDS=0.5
